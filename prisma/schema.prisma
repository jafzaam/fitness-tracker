generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String?
  weight      Float?
  height      Float?
  calorieGoal Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities  Activity[]
  meals       Meal[]
  customFoods CustomFood[]
  userBadges  UserBadge[]
}

model CustomFood {
  id        String   @id @default(cuid())
  userId    String
  name      String
  calories  Int
  protein   Float
  carbs     Float
  fat       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals     Meal[]
}

model Meal {
  id           String      @id @default(cuid())
  userId       String
  customFoodId String?
  name         String?
  calories     Int
  protein      Float?
  carbs        Float?
  fat          Float?
  type         String // e.g., BREAKFAST, LUNCH, DINNER, SNACK
  date         DateTime
  createdAt    DateTime    @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customFood   CustomFood? @relation(fields: [customFoodId], references: [id], onDelete: SetNull)
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  type      String // e.g., RUNNING, CYCLING
  distance  Float? // In km
  duration  Int? // In seconds
  pace      Float? // min/km
  source    String? // e.g., STRAVA, MANUAL
  date      DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  createdAt   DateTime @default(now())

  userBadges  UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId]) // A user can only unlock a specific badge once
}
